# Hybrid Cloud Controller - Environment Variables
# Copy this file to .env and update with your actual values

# Database Configuration
DB_PASSWORD=dev_password_change_me
DATABASE_URL=postgresql://hybrid_cloud_user:dev_password_change_me@localhost:5432/hybrid_cloud

# Security Configuration
# Generate a secure random key for production: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=dev-encryption-key-32-bytes-long
SECRET_KEY=dev-secret-key-change-in-production

# LocalStack Configuration
# For Docker: use service name (http://localstack:4566)
# For local development: use localhost (http://localhost:4566)
LOCALSTACK_ENDPOINT=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# Application Configuration
FLASK_ENV=development
FLASK_APP=packages.api.app:create_app
REQUIRE_HTTPS=false

# API Configuration
API_BASE_URL=http://localhost:10000

# Session Configuration
SESSION_TIMEOUT_MINUTES=30

# Logging Configuration
LOG_LEVEL=INFO
