# Hybrid Cloud Controller - Production Environment Variables Template
# IMPORTANT: This is a TEMPLATE file with placeholders
# Copy this file to .env.production and replace all CHANGE_ME values
# DO NOT commit .env.production or .env to version control

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# SECURITY: Change this password to a strong random value
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://hybrid_cloud_user:CHANGE_ME_STRONG_PASSWORD_HERE@database:5432/hybrid_cloud

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# CRITICAL: Generate secure random keys for production
# Generate ENCRYPTION_KEY (32 bytes hex): python -c "import secrets; print(secrets.token_hex(32))"
# Generate SECRET_KEY (64 bytes hex): python -c "import secrets; print(secrets.token_hex(64))"

# Encryption key for credential storage (must be 32 bytes when hex-decoded)
ENCRYPTION_KEY=CHANGE_ME_RUN_PYTHON_COMMAND_ABOVE_32_BYTES

# Flask secret key for session management (should be long and random)
SECRET_KEY=CHANGE_ME_RUN_PYTHON_COMMAND_ABOVE_64_BYTES

# ============================================================================
# AWS CONFIGURATION
# ============================================================================
# For LocalStack (development/testing)
LOCALSTACK_ENDPOINT=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# For Real AWS (production) - uncomment and configure:
# LOCALSTACK_ENDPOINT=
# AWS_ACCESS_KEY_ID=your_real_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_real_aws_secret_key
# AWS_DEFAULT_REGION=us-east-1

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
FLASK_ENV=production
FLASK_APP=packages.api.app:create_app

# HTTPS Configuration
# IMPORTANT: Set to true in production with proper SSL/TLS certificates
REQUIRE_HTTPS=true

# API Configuration
API_BASE_URL=http://api:10000

# Session Configuration
SESSION_TIMEOUT_MINUTES=30

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# MONITORING CONFIGURATION
# ============================================================================
# Metrics collection interval (seconds)
METRICS_COLLECTION_INTERVAL=30

# Alert thresholds
CPU_ALERT_THRESHOLD=80
MEMORY_ALERT_THRESHOLD=80
STORAGE_ALERT_THRESHOLD=85

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
# Database backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# ============================================================================
# RATE LIMITING (Future Enhancement)
# ============================================================================
# RATE_LIMIT_PER_MINUTE=60
# LOGIN_ATTEMPTS_MAX=5
# LOGIN_LOCKOUT_MINUTES=15

